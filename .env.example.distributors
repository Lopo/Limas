# Distributor API Secrets — Example
# Copy and adjust these settings into your .env.local file.
#
# Locale / currency / sandbox / store-id defaults live in
# config/limas.yaml under `limas.distributors.*`. Edit there if you need
# to change region or currency; .env stays focused on actual secrets.

# DigiKey API
# Production: https://developer.digikey.com/
# Sandbox:    https://sandbox.digikey.com/api
# Sandbox / locale defaults: limas.distributors.digikey.* in limas.yaml
DIGIKEY_ID=your-digikey-client-id
DIGIKEY_SECRET=your-digikey-client-secret

# TME API
# Get credentials from: https://developers.tme.eu/
# Country default: limas.distributors.tme.country
TME_TOKEN=your-tme-token
TME_SECRET=your-tme-app-secret

# Farnell / element14 family (Farnell EU + Newark US + element14 APAC).
# One key serves all three; the store IDs are picked up from
# limas.distributors.{element14,newark,element14apac}.store in limas.yaml.
# Get key: https://partner.element14.com/
ELEMENT14_KEY=your-element14-api-key
# Optional contract pricing (leave empty if you don't have customer-specific pricing):
ELEMENT14_CUSTOMER_ID=
ELEMENT14_SECRET_KEY=

# Octopart / Nexar API (GraphQL)
# Get credentials from: https://nexar.com/
# Note: free tier discontinued — this is the legacy fallback that runs
# alongside the Aggregator. Country/currency defaults:
# limas.distributors.nexar.* in limas.yaml.
NEXAR_ID=your-nexar-client-id
NEXAR_SECRET=your-nexar-client-secret

# OEMSecrets — Part Search API (https://oemsecretsapi.com)
# Meta-aggregator covering ~33 downstream distributors (Future, Avnet,
# Verical, TTI, EBV, Ozdisan, Heilind, …). Adapter filters out sources
# already wired directly (DigiKey/Mouser/TME/Farnell/Newark/element14)
# so it only contributes novel distributor coverage.
# Sign up: https://www.oemsecrets.com/api — testing tier is 10 req/day;
# production limit raised after manual review.
# Country / currency defaults: limas.distributors.oemsecrets.* in limas.yaml.
OEMSECRETS_API_KEY=your-oemsecrets-api-key

# LCSC — no key required. The adapter uses jlcsearch.tscircuit.com for
# keyword/MPN search and LCSC's wmsc.lcsc.com product-detail endpoint
# (both unauthenticated). To enable, set limas.distributors.lcsc.enabled
# to true in config/limas.yaml. Currency default also lives there.

# RSComponents API
# Not publicly available — B2B partners only.
